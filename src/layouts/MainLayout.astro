---
import Navigation from '../components/Navigation.astro';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<html lang="uk">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
		<ClientRouter />
		<script is:inline>
			const root = document.documentElement;
			const supportsViewTransition = typeof document.startViewTransition === 'function';

			const suppressThemeTransitions = () => {
				root.classList.add('theme-switching');
				// Force style recalculation so transition suppression applies immediately.
				void root.offsetHeight;
				requestAnimationFrame(() => {
					requestAnimationFrame(() => {
						root.classList.remove('theme-switching');
					});
				});
			};

			const setTheme = (theme) => {
				root.classList.toggle('dark', theme === 'dark');
				root.style.colorScheme = theme;
			};

			const setThemeWithAnimation = (theme) => {
				suppressThemeTransitions();
				if (supportsViewTransition) {
					document.startViewTransition(() => setTheme(theme));
					return;
				}
				setTheme(theme);
			};

			const applyTheme = () => {
				const theme = localStorage.getItem('theme') || 
				(window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
				setTheme(theme);
			};

			// Запускаємо одразу при прямому заході на сайт
			applyTheme();

			// МАГІЯ ТУТ: втручаємося ПЕРЕД підміною DOM під час переходів
			document.addEventListener('astro:before-swap', (e) => {
				const isDark = root.classList.contains('dark');
				e.newDocument.documentElement.classList.toggle('dark', isDark);
				e.newDocument.documentElement.style.colorScheme = isDark ? 'dark' : 'light';
			});

			document.addEventListener('click', (event) => {
				const target = event.target;
				if (!(target instanceof Element)) return;
				const toggleButton = target.closest('#theme-toggle');
				if (!toggleButton) return;

				event.preventDefault();
				event.stopPropagation();

				const nextTheme = root.classList.contains('dark') ? 'light' : 'dark';
				localStorage.setItem('theme', nextTheme);
				setThemeWithAnimation(nextTheme);
			}, true);
		</script>
	</head>
	
<body class="bg-[#fbfbfd] text-[#1d1d1f] antialiased dark:bg-[#000] dark:text-[#f5f5f7] min-h-screen relative z-0 selection:bg-blue-100 dark:selection:bg-blue-900/30 transition-colors duration-500">
			
		<div class="absolute inset-0 z-[-20] parallax-container" aria-hidden="true">
			
			<div class="absolute top-[-5%] right-[-5%] w-[600px] h-[600px] 
						bg-cyan-400/40 rounded-full blur-[120px] 
						animate-blob layer-fast mix-blend-screen dark:mix-blend-plus-lighter">
			</div>
			
			<div class="absolute top-[20%] left-[-10%] w-[700px] h-[700px] 
						bg-purple-500/30 rounded-full blur-[140px] 
						animate-blob-reverse layer-slow mix-blend-multiply dark:mix-blend-screen">
			</div>

			<div class="absolute bottom-[20%] right-[25%] w-[400px] h-[400px] 
						bg-rose-400/25 rounded-full blur-[100px] 
						animate-blob layer-base mix-blend-screen">
			</div>

		</div>
		<Navigation />
		
		<main class="relative z-10 max-w-6xl mx-auto px-6 pt-24 pb-20">
			<slot />
		</main>

		</body>
</html>