---
const navItems = [
  { name: 'Про мене', href: '#about' },
  { name: 'Проєкти', href: '#projects' },
  { name: 'Контакти', href: '#contact' },
];
---

<nav class="fixed top-0 left-0 w-full z-50 glass border-b border-black/5 dark:border-white/5">
  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    
    <a href="/" class="flex items-center gap-2 group">
      <div class="size-6 bg-gradient-to-tr from-blue-600 to-cyan-400 rounded-lg group-hover:rotate-12 transition-transform shadow-lg shadow-blue-500/20"></div>
      <span class="font-bold tracking-tight text-lg">rostyslav.dev</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navItems.map(item => (
        <a href={item.href} class="text-[13px] font-medium opacity-60 hover:opacity-100 transition-opacity">
          {item.name}
        </a>
      ))}
      <a href="https://github.com/iamavasya" class="px-4 py-1.5 bg-black dark:bg-white text-white dark:text-black rounded-full text-xs font-bold hover:scale-105 transition-transform">
        GitHub
      </a>
    </div>

  </div>
</nav>