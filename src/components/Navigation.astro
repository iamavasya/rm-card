---
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
  { name: 'Про мене', href: '/#about' },
  { name: 'Проєкти', href: '/#projects' },
  { name: 'Контакти', href: '/#contacts' },
];
---

<nav id="navbar" class="sticky top-0 left-0 w-full z-50 transition-all duration-500 bg-transparent border-b border-transparent">

  <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between relative z-50">
    
    <a href="/" class="flex items-center gap-2 group shrink-0">
      <div class="size-6 bg-gradient-to-tr from-blue-600 to-cyan-400 rounded-lg group-hover:rotate-12 transition-transform shadow-lg shadow-blue-500/20"></div>
      <span class="font-bold tracking-tight text-lg text-[#1d1d1f] dark:text-[#f5f5f7] transition-colors duration-500">
        rostyslav.dev
      </span>
    </a>

    <div class="flex items-center gap-4 md:gap-8">
      
      <div class="hidden md:flex items-center gap-6">
        {navItems.map(item => (
          <a href={item.href} class="text-[13px] font-medium text-[#1d1d1f] dark:text-[#f5f5f7] opacity-60 hover:opacity-100 transition-all duration-500">
            {item.name}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-3 md:gap-4">
        
        <a href="https://github.com/iamavasya" class="hidden md:inline-flex px-4 py-1.5 bg-black dark:bg-[#f5f5f7] text-white dark:text-black rounded-full text-xs font-bold hover:scale-105 transition-all duration-500">
          GitHub
        </a>
        
        <ThemeToggle />

        <button id="mobile-menu-btn" class="md:hidden p-2 -mr-2 text-[#1d1d1f] dark:text-[#f5f5f7] opacity-80 hover:opacity-100 transition-colors duration-500" aria-label="Відкрити меню">
          <svg id="burger-icon" class="size-6 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path id="burger-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

      </div>
    </div>
  </div>

  <div id="mobile-menu" class="absolute top-14 left-0 w-full h-[calc(100vh-3.5rem)] bg-[#fbfbfd]/95 dark:bg-[#000]/95 backdrop-blur-2xl border-t border-black/5 dark:border-white/5 
              transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] origin-top 
              opacity-0 -translate-y-8 pointer-events-none md:hidden flex flex-col z-40">
    
    <div class="flex flex-col px-8 py-10 gap-8 overflow-y-auto">
      {navItems.map(item => (
        <a href={item.href} class="mobile-link text-3xl font-bold tracking-tight text-[#1d1d1f] dark:text-[#f5f5f7] opacity-80 hover:opacity-100 transition-opacity">
          {item.name}
        </a>
      ))}
      
      <div class="pt-8 mt-4 border-t border-black/10 dark:border-white/10">
        <a href="https://github.com/iamavasya" class="inline-flex items-center justify-center w-full gap-3 px-6 py-4 bg-[#1d1d1f] dark:bg-[#f5f5f7] text-[#fbfbfd] dark:text-[#1d1d1f] rounded-2xl text-lg font-bold transition-transform active:scale-95 shadow-lg shadow-black/10 dark:shadow-white/5">
          <svg class="size-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22v3.293c0 .319.192.694.805.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          Перейти на GitHub
        </a>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  const setupNavigation = () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const links = document.querySelectorAll('.mobile-link');
    const burgerPath = document.getElementById('burger-path');
    const burgerIcon = document.getElementById('burger-icon');
    const navbar = document.getElementById('navbar');

    if (!btn || !menu || !navbar) return;

    // ЗБЕРІГАЄМО КЛАСИ В ЗМІННІ, ЩОБ НІЧОГО НЕ ГУБИЛОСЯ
    const solidClasses = ['bg-[#fbfbfd]/95', 'dark:bg-[#000]/95', 'backdrop-blur-xl', 'border-black/5', 'dark:border-white/5'];
    const transparentClasses = ['bg-transparent', 'border-transparent'];

    const handleScroll = () => {
      // Якщо меню відкрите — ігноруємо скрол
      if (!menu.classList.contains('opacity-0')) return;

      if (window.scrollY > 20) {
        navbar.classList.add(...solidClasses);
        navbar.classList.remove(...transparentClasses);
      } else {
        navbar.classList.add(...transparentClasses);
        navbar.classList.remove(...solidClasses);
      }
    };

    const toggleMenu = () => {
      const isOpen = !menu.classList.contains('opacity-0');
      
      if (isOpen) {
        // ЗАКРИВАЄМО МЕНЮ
        menu.classList.add('opacity-0', '-translate-y-8', 'pointer-events-none');
        menu.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
        burgerPath.setAttribute('d', 'M4 6h16M4 12h16M4 18h16'); 
        burgerIcon.classList.remove('rotate-90');
        document.body.style.overflow = '';
        
        // Оновлюємо фон залежно від позиції скролу
        handleScroll();
      } else {
        // ВІДКРИВАЄМО МЕНЮ
        menu.classList.remove('opacity-0', '-translate-y-8', 'pointer-events-none');
        menu.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
        burgerPath.setAttribute('d', 'M6 18L18 6M6 6l12 12');
        burgerIcon.classList.add('rotate-90');
        document.body.style.overflow = 'hidden';
        
        // ПРИМУСОВО заливаємо фон навбару
        navbar.classList.remove(...transparentClasses);
        navbar.classList.add(...solidClasses);
      }
    };

    // Оновлюємо слухачі
    const newBtn = btn.cloneNode(true);
    btn.replaceWith(newBtn);
    newBtn.onclick = toggleMenu;

    links.forEach(link => {
      link.onclick = () => {
        if (!menu.classList.contains('opacity-0')) {
          toggleMenu();
        }
      };
    });

    window.addEventListener('scroll', handleScroll);
    handleScroll(); // Перевірка при завантаженні
  };

  setupNavigation();
  document.addEventListener('astro:page-load', setupNavigation);
</script>