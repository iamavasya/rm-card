---
// src/components/ThemeToggle.astro
---

<button 
  id="theme-toggle" 
  class="group relative z-50 flex size-10 items-center justify-center rounded-full hover:bg-black/5 dark:hover:bg-white/10 transition-colors duration-300 cursor-pointer"
  aria-label="Toggle Dark Mode"
>
  <svg 
    id="sun-icon" 
    class="absolute size-5 text-yellow-500 opacity-0 scale-50 rotate-90 transition-all duration-500 dark:opacity-100 dark:scale-100 dark:rotate-0 pointer-events-none" 
    fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>

  <svg 
    id="moon-icon" 
    class="absolute size-5 text-slate-700 opacity-100 scale-100 rotate-0 transition-all duration-500 dark:opacity-0 dark:scale-50 dark:-rotate-90 pointer-events-none" 
    fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
</button>

<script is:inline>
  const initThemeToggle = () => {
    const toggleBtn = document.getElementById('theme-toggle');
    if (toggleBtn) {
      // Пряме призначення обробника події гарантує, що він спрацює
      toggleBtn.onclick = () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        console.log(`Тема переключена на: ${isDark ? 'dark' : 'light'}`);
      };
    }
  };

  // Запуск при першому відкритті сторінки
  initThemeToggle();
  
  // Перезапуск скрипта після навігації Astro (якщо ти перейдеш на іншу сторінку)
  document.addEventListener('astro:page-load', initThemeToggle);
</script>