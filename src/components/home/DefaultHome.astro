---
import type { CollectionEntry } from 'astro:content';
import ProjectCard from '../ProjectCard.astro';
import IntroCard from '../IntroCard.astro';
import TechStack from '../TechStack.astro';
import Footer from '../Footer.astro';
import Experience from '../Experience.astro';
import EngineeringInsights from '../EngineeringInsights.astro';
import {
  engineeringInsights,
  experienceItems,
  homeCopy,
  techStackContent,
} from '../../data/home';

interface Props {
  introEntry?: CollectionEntry<'intro'>;
  IntroContent?: any;
  projects: CollectionEntry<'projects'>[];
}

const { introEntry, IntroContent, projects } = Astro.props;
---

<section class="max-w-5xl mx-auto px-6 pt-18 text-center animate-fade-up opacity-0">
  <h2 class="text-sm font-semibold tracking-[0.2em] text-blue-600 uppercase mb-4">
    {homeCopy.eyebrow}
  </h2>
  <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-8">
    {homeCopy.headline} <br />
    <span class="text-transparent bg-clip-text bg-gradient-to-b from-[#333] to-[#000] dark:from-[#fff] dark:to-[#888]">
      {homeCopy.headlineAccent}
    </span>
  </h1>
  <p class="text-xl md:text-2xl opacity-50 max-w-2xl mx-auto leading-relaxed">
    {homeCopy.summary}
  </p>
</section>

{introEntry && (
  <section class="max-w-6xl mx-auto px-6 py-12 animate-fade-up opacity-0" style="animation-delay: 0.2s">
    <IntroCard
      title={introEntry.data.title}
      tags={introEntry.data.tags}
      memoji={introEntry.data.memoji}
    >
      {IntroContent && <IntroContent />}
    </IntroCard>
  </section>
)}

<EngineeringInsights insights={engineeringInsights} />

<section id="about" class="max-w-5xl mx-auto px-6 py-32 mt-5 animate-fade-up opacity-0" style="animation-delay: 0.7s">
  <div class="relative z-10 text-center">
    <span class="inline-block text-[11px] font-bold uppercase tracking-[0.3em] text-blue-500 mb-6 opacity-80">
      {homeCopy.philosophyEyebrow}
    </span>

    <h3 class="text-4xl md:text-6xl font-bold mb-8 tracking-tight">
      {homeCopy.philosophyTitle}
    </h3>

    <p class="text-xl md:text-2xl opacity-50 max-w-3xl mx-auto leading-relaxed mb-12 font-medium">
      {homeCopy.philosophyText}
    </p>

    <div class="flex flex-wrap justify-center gap-3">
      {homeCopy.interests.map((item) => (
        <span class="px-6 py-2 border border-black/10 dark:border-white/10 rounded-full text-xs font-semibold tracking-wide hover:border-blue-500/50 active:border-blue-500/50 transition-colors duration-300">
          {item}
        </span>
      ))}
    </div>
  </div>
</section>

<section id="projects" class="max-w-6xl mx-auto px-6 py-20">
  <div class="mb-12 animate-fade-up opacity-0" style="animation-delay: 0.35s">
    <span class="inline-block text-[11px] font-bold uppercase tracking-[0.2em] text-blue-600 dark:text-blue-500 mb-2 opacity-80">
      {homeCopy.projectsEyebrow}
    </span>
    <h2 class="text-4xl font-bold tracking-tight">
      {homeCopy.projectsTitle}
    </h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    {projects.map((project, index) => (
      <div
        class="animate-fade-up opacity-0"
        style={`animation-delay: ${0.45 + index * 0.1}s`}
      >
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          tags={project.data.tags}
          slug={project.id}
          github={project.data.github}
        />
      </div>
    ))}
  </div>
</section>

<section id="experience" class="max-w-6xl mx-auto px-6 py-20">
  <div class="mb-16 animate-fade-up opacity-0" style="animation-delay: 0.8s">
    <span class="inline-block text-[11px] font-bold uppercase tracking-[0.2em] text-blue-600 mb-2">
      {homeCopy.experienceEyebrow}
    </span>
    <h2 class="text-4xl font-bold tracking-tight">{homeCopy.experienceTitle}</h2>
  </div>

  <div class="animate-fade-up opacity-0" style="animation-delay: 0.9s">
    <Experience items={experienceItems} />
  </div>
</section>

<section class="py-20 animate-fade-up opacity-0" style="animation-delay: 1s">
  <TechStack content={techStackContent} />
</section>

<section id="contacts">
  <Footer />
</section>
