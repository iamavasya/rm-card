---
import { siteConfig } from '../data/config';
import { Image } from 'astro:assets';
import memojiFooter from '../assets/memoji-footer.png';
import { Icon } from 'astro-icon/components';

const currentYear = new Date().getFullYear();
const { availabilityStatus, workplace, statusMessages, socials, email } = siteConfig;

const availability = {
  busy: {
    label: `${statusMessages.busy} ${workplace}`,
    dotClass: 'availability-dot availability-dot--busy',
    waveClass: '',
  },
  passive: {
    label: `${statusMessages.passive} ${workplace}`,
    dotClass: 'availability-dot availability-dot--passive',
    waveClass: '',
  },
  open: {
    label: statusMessages.open,
    dotClass: 'availability-dot availability-dot--open',
    waveClass: 'availability-wave availability-wave--open',
  },
}[availabilityStatus];
---

<footer class="relative mt-20 pb-10 border-t border-black/5 dark:border-white/5 transition-colors duration-500">
  <div class="max-w-6xl mx-auto px-6 pt-16">
    <div class="flex flex-col md:flex-row justify-between items-center md:items-center gap-12 md:gap-10">
      <div class="flex flex-col items-center md:items-start gap-6 text-center md:text-left">
        <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/5 dark:bg-white/5 border border-black/5 dark:border-white/10 backdrop-blur-md md:self-start">
          <div class={availability.dotClass}>
            {availability.waveClass && <div class={availability.waveClass}></div>}
          </div>
          <span class="text-xs font-bold tracking-wide uppercase text-[#1d1d1f] dark:text-[#f5f5f7] opacity-80 transition-colors duration-500">
            {availability.label}
          </span>
        </div>

        <div class="flex flex-col gap-2">
          <h2 class="text-2xl font-bold tracking-tight text-[#1d1d1f] dark:text-[#f5f5f7] transition-colors duration-500">
            Ростислав <span class="text-blue-600">.</span>
          </h2>
          <p class="text-sm opacity-50 text-[#1d1d1f] dark:text-[#f5f5f7] transition-colors duration-500">
            © {currentYear} Створено з кавою та кодом у Тернополі.
          </p>
        </div>
      </div>

      <div class="flex flex-col items-center gap-4 w-full md:w-auto lg:flex-row md:gap-4">
        <button
          id="copy-email"
          data-email={email}
          class="h-12 px-5 flex items-center gap-3 rounded-2xl overflow-hidden isolate [transform:translateZ(0)] [-webkit-transform:translateZ(0)] [backface-visibility:hidden] [-webkit-backface-visibility:hidden] [-webkit-tap-highlight-color:transparent] bg-white/5 dark:bg-[#161617]/40 border border-black/5 dark:border-white/10 transition-all duration-500 hover:scale-105 hover:border-blue-500/30 active:scale-105 active:border-blue-500/30 focus-visible:scale-105 group cursor-pointer relative"
        >
          <Icon name="simple-icons:gmail" class="size-5 text-[#1d1d1f] dark:text-[#f5f5f7] opacity-60 group-hover:opacity-100 group-active:opacity-100 transition-all duration-500" />

          <span id="email-text" class="text-[11px] font-bold tracking-tight text-[#1d1d1f] dark:text-[#f5f5f7] opacity-60 group-hover:opacity-100 group-active:opacity-100 transition-all duration-500">
            {email}
          </span>
        </button>

        <div class="grid grid-cols-4 gap-2">
          {socials.map((social) => (
            <a
              href={social.href}
              aria-label={social.name}
              class="size-12 flex items-center justify-center rounded-2xl overflow-hidden isolate [transform:translateZ(0)] [-webkit-transform:translateZ(0)] [backface-visibility:hidden] [-webkit-backface-visibility:hidden] [-webkit-tap-highlight-color:transparent] bg-white/5 dark:bg-[#161617]/40 border border-black/5 dark:border-white/10 transition-all duration-500 hover:scale-110 hover:border-blue-500/30 active:scale-110 active:border-blue-500/30 focus-visible:scale-110 group"
            >
              <Icon
                name={social.icon}
                class="size-5 text-[#1d1d1f] dark:text-[#f5f5f7] opacity-60 group-hover:opacity-100 group-active:opacity-100 transition-all duration-500"
              />
            </a>
          ))}
        </div>
      </div>

      <div class="relative shrink-0">
        <div class="pointer-events-none select-none absolute inset-0 bg-blue-500/20 blur-[25px] rounded-full" aria-hidden="true"></div>

        <div class="transition-transform duration-500 ease-out hover:scale-125 active:scale-125">
          <Image
            src={memojiFooter}
            alt="Peace Memoji"
            format="webp"
            width={200}
            height={200}
            class="size-28 md:size-32 relative z-10 animate-memoji-swing drop-shadow-2xl object-contain"
          />
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .availability-dot {
    position: relative;
    width: 0.625rem;
    height: 0.625rem;
    flex: 0 0 0.625rem;
    border-radius: 9999px;
  }

  .availability-dot--busy {
    background: #ef4444;
    overflow: hidden;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.22);
  }

  .availability-dot--busy::after {
    content: '';
    position: absolute;
    inset: 1px;
    border-radius: inherit;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.78) 0%, rgba(248, 113, 113, 0.45) 42%, rgba(239, 68, 68, 0) 72%);
    opacity: 0.32;
    animation: availability-busy-inner-glow 1.8s ease-in-out infinite;
  }

  .availability-dot--passive {
    background: #f59e0b;
    box-shadow: 0 0 10px rgba(245, 158, 11, 0.55);
    animation: availability-passive-pulse 1.7s ease-in-out infinite;
  }

  .availability-dot--open {
    background: #10b981;
    box-shadow: 0 0 10px rgba(16, 185, 129, 0.65);
  }

  .availability-wave {
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  .availability-wave--open {
    background: #10b981;
    opacity: 0.75;
    animation: availability-open-wave 1s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes availability-busy-inner-glow {
    0%, 100% {
      opacity: 0.22;
    }
    50% {
      opacity: 0.88;
    }
  }

  @keyframes availability-passive-pulse {
    0%, 100% {
      transform: scale(1);
      background: #f59e0b;
      box-shadow: 0 0 8px rgba(245, 158, 11, 0.42);
    }
    50% {
      transform: scale(1.35);
      background: #fbbf24;
      box-shadow: 0 0 14px rgba(251, 191, 36, 0.72);
    }
  }

  @keyframes availability-open-wave {
    75%, 100% {
      transform: scale(2);
      opacity: 0;
    }
  }
</style>

<script is:inline>
  const setupCopyEmailButton = () => {
    const copyBtn = document.getElementById('copy-email');
    const emailText = document.getElementById('email-text');

    if (!(copyBtn instanceof HTMLButtonElement)) return;
    if (!(emailText instanceof HTMLElement)) return;

    copyBtn.onclick = async () => {
      const email = copyBtn.getAttribute('data-email') ?? '';
      if (!email) return;

      try {
        await navigator.clipboard.writeText(email);
      } catch {
        return;
      }

      const originalText = emailText.innerText;
      emailText.innerText = 'Copied!';

      setTimeout(() => {
        emailText.innerText = originalText;
      }, 2000);
    };
  };

  setupCopyEmailButton();
  document.addEventListener('astro:page-load', setupCopyEmailButton);
</script>
