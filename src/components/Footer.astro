---
// src/components/Footer.astro
import { siteConfig } from '../data/config';
import { Image } from 'astro:assets';
import memojiFooter from '../assets/memoji-footer.png';
import { Icon } from 'astro-icon/components';

const currentYear = new Date().getFullYear();
const { isOpenToWork, workplace, statusMessages, socials } = siteConfig;

const displayStatus = isOpenToWork 
  ? statusMessages.open 
  : `${statusMessages.busy} ${workplace}`;
---

<footer class="relative mt-20 pb-10 border-t border-black/5 dark:border-white/5 transition-colors duration-500">
  <div class="max-w-6xl mx-auto px-6 pt-16">
    <div class="flex flex-col md:flex-row justify-between items-center md:items-center gap-12 md:gap-10">
      
      <div class="flex flex-col items-center md:items-start gap-6 text-center md:text-left">
        <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white/5 dark:bg-white/5 border border-black/5 dark:border-white/10 backdrop-blur-md md:self-start">
          <div class={`relative size-2.5 rounded-full ${isOpenToWork ? 'bg-emerald-500 shadow-[0_0_10px_#10b981]' : 'bg-amber-500 shadow-[0_0_10px_#f59e0b]'}`}>
            <div class={`absolute inset-0 rounded-full animate-ping opacity-75 ${isOpenToWork ? 'bg-emerald-500' : 'bg-amber-500'}`}></div>
          </div>
          <span class="text-xs font-bold tracking-wide uppercase text-[#1d1d1f] dark:text-[#f5f5f7] opacity-80 transition-colors duration-500">
            {displayStatus}
          </span>
        </div>

        <div class="flex flex-col gap-2">
          <h2 class="text-2xl font-bold tracking-tight text-[#1d1d1f] dark:text-[#f5f5f7] transition-colors duration-500">
            Ростислав <span class="text-blue-600">.</span>
          </h2>
          <p class="text-sm opacity-50 text-[#1d1d1f] dark:text-[#f5f5f7] transition-colors duration-500">
            © {currentYear} Створено з кавою та кодом у Тернополі.
          </p>
        </div>
      </div>

      <div class="flex flex-wrap justify-center items-center gap-4">
        {socials.map((social) => (
          <a 
            href={social.href} 
            aria-label={social.name}
            class="size-12 flex items-center justify-center rounded-2xl bg-white/5 dark:bg-[#161617]/40 border border-black/5 dark:border-white/10 transition-all duration-500 hover:scale-110 hover:border-blue-500/30 group"
          >
            <Icon 
              name={social.icon} 
              class="size-5 text-[#1d1d1f] dark:text-[#f5f5f7] opacity-60 group-hover:opacity-100 transition-all duration-500" 
            />
          </a>
        ))}
      </div>

      <div class="relative shrink-0">
        <div class="absolute inset-0 bg-blue-500/20 blur-[25px] rounded-full"></div>
        
        <div class="transition-transform duration-500 ease-out hover:scale-125">
            <Image 
              src={memojiFooter} 
              alt="Peace Memoji" 
              format="webp"
              width={200}
              height={200}
              class="size-28 md:size-32 relative z-10 animate-memoji-swing drop-shadow-2xl object-contain"
            />
        </div>
      </div>

    </div>
  </div>
</footer>